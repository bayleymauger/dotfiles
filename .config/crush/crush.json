{
  "$schema": "https://charm.land/crush.json",
  "lsp": {
    "Go": {
      "command": "gopls"
    },
    "TypeScript": {
      "command": "typescript-language-server",
      "args": [
        "--stdio"
      ]
    },
    "Bash": {
      "command": "bash-language-server",
      "args": [
        "start"
      ]
    }
  },
  "mcp": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "$(echo Bearer $GITHUB_TOKEN)"
      }
    },
    "context7": {
      "type": "http",
      "timeout": 30,
      "url": "https://mcp.context7.com/mcp"
    },
    "fff": {
      "type": "stdio",
      "command": "fff-mcp"
    }
  },
  "permissions": {
    "allowed_tools": [
      "fff_multi_grep",
      "fff_grep",
      "fff_find_files",
      "agentic_fetch",
      "lsp_references",
      "lsp_diagnostics",
      "sourcegraph",
      "read_mcp_resource",
      "multiedit",
      "view",
      "ls",
      "grep",
      "fetch",
      "write",
      "edit"
    ]
  }
}
