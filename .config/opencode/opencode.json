{
	"$schema": "https://opencode.ai/config.json",
	"model": "anthropic/claude-sonnet-4-6",
	"autoupdate": true,
	"server": {
		"port": 4096,
	},
	"mcp": {
		"github": {
			"type": "remote",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"Authorization": "{env:GITHUB_TOKEN}"
			},
		},
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		}
	}
}
